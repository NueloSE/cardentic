# =============================================================================
# CARDENTIC — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# =============================================================================

# -----------------------------------------------------------------------------
# STRIPE (Test Mode only — use keys from dashboard.stripe.com/test/apikeys)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get this by running: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# STELLAR TESTNET WALLETS
# Generate keypairs at: https://laboratory.stellar.org/#account-creator?network=test
# Fund with Friendbot: https://friendbot.stellar.org/?addr=YOUR_PUBLIC_KEY
# Fund with testnet USDC at: https://xlm402.com or request from Stellar discord
#
# IMPORTANT: All these wallets need XLM (for fees) AND USDC trustlines
# -----------------------------------------------------------------------------

# Treasury wallet — simulates fiat->USDC conversion after Stripe payment
STELLAR_TREASURY_SECRET_KEY=S...
STELLAR_TREASURY_PUBLIC_KEY=G...

# Boss Agent wallet — receives USDC from treasury, pays sub-agents
STELLAR_BOSS_SECRET_KEY=S...
STELLAR_BOSS_PUBLIC_KEY=G...

# Sub-agent wallets — receive x402 micropayments from boss
STELLAR_AGENT_FLIGHT_SECRET_KEY=S...
STELLAR_AGENT_FLIGHT_PUBLIC_KEY=G...

STELLAR_AGENT_HOTEL_SECRET_KEY=S...
STELLAR_AGENT_HOTEL_PUBLIC_KEY=G...

STELLAR_AGENT_ACTIVITY_SECRET_KEY=S...
STELLAR_AGENT_ACTIVITY_PUBLIC_KEY=G...

STELLAR_AGENT_SUMMARIZER_SECRET_KEY=S...
STELLAR_AGENT_SUMMARIZER_PUBLIC_KEY=G...

# -----------------------------------------------------------------------------
# STELLAR NETWORK CONFIG (do not change for testnet)
# -----------------------------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Testnet USDC issued by Circle on Stellar testnet
STELLAR_USDC_ASSET_CODE=USDC
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# -----------------------------------------------------------------------------
# x402 CONFIG
# Public facilitator supports stellar:testnet (fees sponsored by Coinbase/OZ)
# -----------------------------------------------------------------------------
X402_FACILITATOR_URL=https://www.x402.org/facilitator
X402_NETWORK=stellar:testnet

# -----------------------------------------------------------------------------
# AI / LLM
# Get from: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Amount user pays in USD cents (1000 = $10.00)
STRIPE_PAYMENT_AMOUNT=1000
# Amount in USDC sent to boss agent after payment
BOSS_AGENT_USDC_AMOUNT=10
